APP_ENV=dev
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/financial_manager
JWT_SECRET_KEY=change-me
JWT_EXPIRE_SECONDS=7200

# 可选：Streamlit Web 调用的后端 API 根（默认 http://127.0.0.1:8000/api/v1）
# FM_API_BASE=http://127.0.0.1:8000/api/v1
# 可选：调用 API 的超时秒数（默认 45）
# FM_API_TIMEOUT=45

# 可选：在 uvicorn 进程内启用每日 02:00 同步证券参考价（多 worker 时请改外部 cron 调 scripts/sync_asset_ref_prices.py）
# FM_REF_PRICE_CRON=1
# FM_REF_PRICE_TZ=Asia/Shanghai

# 可选：Streamlit 登录态 Cookie（刷新页面后保持登录）。生产若仍掉登录：① 反代须转发 Cookie 头
# （如 Nginx：proxy_set_header Cookie $http_cookie; 并正确设置 X-Forwarded-Proto）；
# ② 子路径部署时 Path 与地址栏前缀一致：FM_AUTH_COOKIE_PATH=/myapp
# ③ 跨站嵌入：FM_AUTH_COOKIE_SAMESITE=none（仅 HTTPS，脚本会自动加 Secure）
# ④ 多子域共享 fm_auth：FM_AUTH_COOKIE_DOMAIN=.example.com
# ⑤ FM_API_BASE 若指向错误环境会首屏 401，逻辑会清 Cookie 并回登录页，须与 JWT 签发端一致。
# ⑥ CookieManager 的 Secure：本地 http 可写 FM_AUTH_COOKIE_SECURE=0；HTTPS 生产可省略或 FM_AUTH_COOKIE_SECURE=1
# ⑦ 登录态诊断：Streamlit 进程终端打印 [fm_auth_debug]（不含 token 全文）；复现刷新掉登录时开启
# FM_AUTH_DEBUG=1
