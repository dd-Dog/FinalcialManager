APP_ENV=dev
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/financial_manager
JWT_SECRET_KEY=change-me
JWT_EXPIRE_SECONDS=7200

# 可选：Streamlit Web 调用的后端 API 根（默认 http://127.0.0.1:8000/api/v1）
# FM_API_BASE=http://127.0.0.1:8000/api/v1
# 可选：调用 API 的超时秒数（默认 45）
# FM_API_TIMEOUT=45

# 可选：在 uvicorn 进程内启用每日 02:00 同步证券参考价（多 worker 时请改外部 cron 调 scripts/sync_asset_ref_prices.py）
# FM_REF_PRICE_CRON=1
# FM_REF_PRICE_TZ=Asia/Shanghai

# 可选：Streamlit 登录态 Cookie（刷新页面后保持登录）。生产若仍掉登录：① 反代须转发 Cookie；
# ② 若应用挂在子路径（如 https://host/myapp/），Path 须与访问前缀一致：
# FM_AUTH_COOKIE_PATH=/myapp
# ③ 仅当页面被跨站嵌入且需带 Cookie 时使用 none（仅 HTTPS，且自动 Secure）：
# FM_AUTH_COOKIE_SAMESITE=none
